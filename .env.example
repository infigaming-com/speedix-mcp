# Meepo Backoffice API
# Default: https://apiport.xyz (production)
# Only override for dev/staging environments
# MEEPO_API_BASE_URL=https://apiport.xyz

# Authentication (optional - can use login tool instead)
# Default: https://bo.speedixadm.com (production)
# Override with your operator's backoffice subdomain if needed
# MEEPO_ORIGIN=https://your-backoffice.meepo.site
MEEPO_EMAIL=admin@example.com
MEEPO_PASSWORD=your-password

# 2FA auto-login (optional - can use complete_2fa_login tool instead)
# MEEPO_TOTP_SECRET=YOUR_BASE32_TOTP_SECRET
